<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pricing Table</title>
    <link rel="stylesheet" href="./style.css">
</head>
<body>
    <main class="page-shell">
        <section class="pricing-shell">
            <header class="pricing-header">
                <h2>Choose your plan</h2>
                <p>Find the right package for your needs, from starter to premium access.</p>
            </header>
            <div class="pricing-grid">
                <article class="pricing-card">
                    <h3>Basic</h3>
                    <p class="price">$9<span>/mo</span></p>
                    <ul>
                        <li>Essential features</li>
                        <li>5 projects</li>
                        <li>Email support</li>
                    </ul>
                    <button type="button">Select Basic</button>
                </article>
                <article class="pricing-card featured">
                    <h3>Pro</h3>
                    <p class="price">$24<span>/mo</span></p>
                    <ul>
                        <li>Everything in Basic</li>
                        <li>Unlimited projects</li>
                        <li>Priority support</li>
                    </ul>
                    <button type="button">Select Pro</button>
                </article>
                <article class="pricing-card">
                    <h3>Premium</h3>
                    <p class="price">$49<span>/mo</span></p>
                    <ul>
                        <li>All Pro features</li>
                        <li>Advanced reports</li>
                        <li>Dedicated onboarding</li>
                    </ul>
                    <button type="button">Select Premium</button>
                </article>
            </div>
        </section>
    </main>
</body>
</html>
       
